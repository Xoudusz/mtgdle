# Override the daily card for testing (card name must exist in data/cards.json)
TEST_CARD=Lightning Bolt

# Offset daily card selection without changing date (shifts pool index)
CARD_SEED=0

# Disable localStorage persistence for testing (every load starts fresh)
NEXT_PUBLIC_NO_CACHE=true

# PocketBase URL for stats
# Local dev: run pocketbase binary on port 8090
# Production: uses http://mtgdle-pb:8090 (set in docker-compose.yml)
POCKETBASE_URL=http://localhost:8090

# PocketBase admin credentials (auto-creates superuser on first start)
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=changeme
